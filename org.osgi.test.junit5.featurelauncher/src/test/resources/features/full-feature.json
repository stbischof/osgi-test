	"configurations": {
		"org.apache.felix.http": {
			"org.apache.felix.http.enable": false
		},
		"org.apache.felix.http~http1": {
			"org.osgi.service.http.port": 8181,
			"org.apache.felix.http.runtime.init.id": "http1",
			"test.string": "hello",
			"test.int:Integer": 42,
			"test.long:Long": 123456789,
			"test.boolean": true,
			"test.double": 3.14
		},
		"org.apache.felix.http~http2": {
			"org.osgi.service.http.port": 8182,
			"org.apache.felix.http.runtime.init.id": "http2"
		},
		"org.apache.felix.http~http3": {
			"org.osgi.service.http.port": 8183,
			"org.apache.felix.http.runtime.init.id": "http3"
		},
		"JakartarsServletWhiteboardRuntimeComponent~rest1": {
			"jersey.jakartars.whiteboard.name": "REST Whiteboard 1",
			"jersey.context.path": "rest1",
			"osgi.http.whiteboard.target": "(id=http1)"
		},
		"JakartarsServletWhiteboardRuntimeComponent~rest2": {
			"jersey.jakartars.whiteboard.name": "REST Whiteboard 2",
			"jersey.context.path": "rest2",
			"osgi.http.whiteboard.target": "(id=http2)"
		},
		"org.eclipse.osgi.technology.featurelauncher.test.typecheck": {
			"string.value": "hello",
			"int.value:Integer": 42,
			"long.value:Long": 123456789,
			"boolean.value": true,
			"double.value": 3.14,
			"string.array": ["alpha", "beta", "gamma"]
		}
	}
